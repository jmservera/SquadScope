# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Local Hugo tooling and build output
.tools/
public/
resources/_gen/
.hugo_build.lock

# Node.js dependencies
node_modules/

# Python virtual environments and caches
.venv
.venv/
venv/
__pycache__/
*.py[cod]

# Tooling caches (ruff / pytest — created by local pre-commit hooks)
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Secrets / environment files
.env
.env.*
!.env.example

# Build / distribution output
dist/
build/

# OS files
.DS_Store

# IDE / editor settings
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Git worktrees
.worktrees/
*.pyc
.squad/.cache/

# Runtime temp files
.agent_tmp/
.ralph/
ralph_squadscope.log
squadscope-agent-result.json
data/metrics/observability/

# Local copilot skills (machine-specific)
.copilot/

# Squad memory (runtime state)
.squad/memory/
.squad/reskill/
.squad/casting-*.json
.ralph_tick.log
.squad/ralph-circuit-breaker.json
.squad/.watch-pids
